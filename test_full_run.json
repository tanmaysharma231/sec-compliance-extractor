      "rule_provision": "Form 8-K Item 1.05",
      "obligation_text": "Registrants must file Form 8-K disclosing a material cybersecurity incident within 4 business days of determining it is material.",
      "trigger": "Incident determined material",
      "deadline": "4 business days",
      "disclosure_fields": [
