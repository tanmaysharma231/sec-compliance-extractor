  "rule_summary": {
    "summary": "The SEC has implemented new rules to standardize disclosures on cybersecurity risk management, strategy, and incidents for public companies. These rules require current disclosures of material cybersecurity incidents and periodic disclosures regarding risk management processes, board oversight, and governance, all of which must be presented in Inline XBRL. The rules are effective September 5, 2023, with compliance required from December 15, 2023, for certain disclosures and other specified dates for smaller reporting companies.",
    "citations": [
      "src:0",
      "src:78"
    ]
  },
